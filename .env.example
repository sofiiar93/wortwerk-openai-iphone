# OpenAI API — server-only. Never expose this key in client components.
OPENAI_API_KEY=

# Recommended cheap default for MVP. Use gpt-5.5 for higher quality if cost is acceptable.
OPENAI_MODEL=gpt-5.4-mini

# Firebase public config. Demo mode works without Firebase.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
